              "raw": "{\n  \"name\": \"admin\",\n  \"permissions\": [\"users:read\", \"users:create\", \"users:update\", \"users:delete\", \"roles:read\", \"roles:create\", \"roles:update\", \"roles:delete\"]\n}"
            }
          },
